@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/orders/ORD-2024-001234>
    a schema:Order ;
    schema:orderNumber "ORD-2024-001234" ;
    schema:orderDate "2024-03-15T14:30:00Z"^^xsd:dateTime ;
    schema:customer <https://schema.org/organization/sonjasteiner> ;
    schema:seller <https://schema.org/organization/flaschenpost> ;
    schema:orderedItem <https://example.com/orders/ORD-2024-001234#1> , <https://example.com/orders/ORD-2024-001234#2>.

<https://schema.org/organization/sonjasteiner>
    a schema:Organization ;
    schema:name "Sonja Steiner" ;
    schema:email "sonja.steiner@acons.ch" .

<https://schema.org/organization/flaschenpost>
    a schema:Organization ;
    schema:name "Flaschenpost" ;
    schema:email "info@flaschenpost.ch" ;
    schema:url <https://flaschenpost.ch> .

<https://example.com/orders/ORD-2024-001234#1>
    a schema:OrderItemDetail ;
    schema:orderQuantity 6 ;
    schema:orderItemNumber "ITEM-001" ;
    schema:orderedItem <https://schema.org/product/meursault2022> .

<https://example.com/orders/ORD-2024-001234#2>
    a schema:OrderItemDetail ;
    schema:orderQuantity 12 ;
    schema:orderItemNumber "ITEM-002" ;
    schema:orderedItem <https://schema.org/product/pontecanet2019> .

<https://schema.org/product/meursault2022>
    a schema:Product ;
    schema:name "Meursault 1er Cru Château de Blagny 2022" .

<https://schema.org/product/pontecanet2019>
    a schema:Product ;
    schema:name "Château Pontet-Canet 2019" .
